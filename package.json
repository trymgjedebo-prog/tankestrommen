{
  "name": "tankestrommen",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:tankestrom-regression": "vitest run src/lib/tankestrom-regression.test.ts",
    "eval:tankestrom": "tsx --tsconfig tsconfig.json scripts/eval-tankestrom.ts",
    "eval:tankestrom:dry": "tsx --tsconfig tsconfig.json scripts/eval-tankestrom.ts --dry",
    "eval:tankestrom:live": "tsx --tsconfig tsconfig.json scripts/eval-tankestrom-live.ts",
    "eval:tankestrom:live:mini": "tsx --tsconfig tsconfig.json scripts/eval-tankestrom-live.ts --model=gpt-5.4-mini",
    "eval:tankestrom:live:strong": "tsx --tsconfig tsconfig.json scripts/eval-tankestrom-live.ts --model=gpt-5.4",
    "eval:school:replay:smoke": "tsx --tsconfig tsconfig.json src/evals/school-replay/run-school-replay.ts src/evals/school-replay/fixtures/smoke",
    "eval:school:semantic:smoke": "tsx --tsconfig tsconfig.json src/evals/school-replay/run-school-semantic-eval.ts src/evals/school-replay/fixtures/smoke"
  },
  "dependencies": {
    "braintrust": "^3.10.0",
    "canvas": "^3.2.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.9.0",
    "next": "^14.2.0",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
